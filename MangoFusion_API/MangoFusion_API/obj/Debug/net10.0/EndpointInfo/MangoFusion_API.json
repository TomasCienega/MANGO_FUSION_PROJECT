        "required": [
          "pickUpName",
          "pickUpPhoneNumber",
          "pickUpEmail"
        ],
        "type": "object",
        "properties": {
          "pickUpName": {
            "type": "string"
          },
          "pickUpPhoneNumber": {
            "type": "string"
          },
          "pickUpEmail": {
            "type": "string"
          },
          "applicationUserId": {
            "type": "string"
          },
          "orderTotal": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "totalItem": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
