            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "OrderDetailsCreateDTO": {
        "required": [
          "menuItemId",
          "quantity",
          "itemName",
          "price"
        ],
        "type": "object",
        "properties": {
          "menuItemId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "quantity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "itemName": {
            "type": "string"
          },
          "price": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "OrderDetailsUpdateDTO": {
        "required": [
          "orderDetailId",
          "rating"
